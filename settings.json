{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/log-skill.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "plugin-dev@claude-code-plugins": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "agentPushNotifEnabled": true,
  "voiceEnabled": true,
  "skipAutoPermissionPrompt": true
}
